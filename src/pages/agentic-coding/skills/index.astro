---
import BaseLayout from "../../../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Skills" description="Reusable agent skills inside the Agentic Coding notes.">
  <section class="hero">
    <div>
      <p class="eyebrow">Agentic Coding / Skills</p>
      <h1>Reusable skills I actually use.</h1>
      <p>
        This page collects agent skills as components inside the broader Agentic Coding section.
        Skills are not the top-level structure of the site; they are reusable building blocks inside my notes.
      </p>
    </div>
    <div class="meta-box">
      <strong>First component</strong>
      <span>Grill Me: a pre-implementation interview skill for clarifying a plan before coding.</span>
    </div>
  </section>

  <section class="section">
    <div class="grid">
      <article class="card">
        <div class="badge-row">
          <span class="badge green">Skill</span>
          <span class="badge">Active</span>
        </div>
        <h2>Grill Me</h2>
        <p>A pre-implementation interview skill that turns vague plans into implementation-ready specs.</p>
        <a href={`${base}components/skills/grill-me/`}>Read component</a>
      </article>
    </div>
  </section>
</BaseLayout>
