---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Verified Skills" description="Verified agent skills inside the Agentic Coding notes.">
  <section class="hero">
    <div>
      <p class="eyebrow">Agentic Coding / Skills / Verified</p>
      <h1>Verified skills I actually use.</h1>
      <p>
        This page collects agent skills as components inside the broader Agentic Coding section.
        Skills are not the top-level structure of the site; they are building blocks inside my notes.
      </p>
    </div>
    <div class="meta-box">
      <strong>Current set</strong>
      <span>Grill Me for planning clarity. TDD for behavior-first implementation loops.</span>
    </div>
  </section>

  <section class="section">
    <div class="grid">
      <article class="card">
        <div class="badge-row">
          <span class="badge green">Skill</span>
          <span class="badge">Active</span>
        </div>
        <h2>Grill Me</h2>
        <p>A pre-implementation interview skill that turns vague plans into implementation-ready specs.</p>
        <a href={`${base}components/skills/grill-me/`}>Read component</a>
      </article>

      <article class="card">
        <div class="badge-row">
          <span class="badge green">Skill</span>
          <span class="badge">External source</span>
        </div>
        <h2>TDD</h2>
        <p>A test-first skill for building behavior through tracer bullets and vertical red-green loops.</p>
        <a href={`${base}components/skills/tdd/`}>Read component</a>
      </article>
    </div>
  </section>
</BaseLayout>
