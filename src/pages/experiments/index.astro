---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Experiments" description="Applied AI experiments.">
  <section class="hero">
    <div>
      <p class="eyebrow">Experiments</p>
      <h1>Experiments from my own AI projects.</h1>
      <p>
        This section tracks experiments I run in public projects. The first focus is AI Wiki Toolkit,
        which is my memory and knowledge-system research project.
      </p>
    </div>
    <div class="meta-box">
      <strong>Current experiment thread</strong>
      <span>AI Wiki Toolkit: building and evaluating memory-oriented workflows for coding agents.</span>
    </div>
  </section>
  <section class="section">
    <div class="grid">
      <article class="card">
        <div class="badge-row">
          <span class="badge green">Active</span>
          <span class="badge">Memory</span>
        </div>
        <h2>AI Wiki Toolkit</h2>
        <p>A public experiment around agent memory, repo knowledge, source synthesis, and durable context for coding workflows.</p>
        <a href="https://github.com/BochengYin/ai-wiki-toolkit">Open GitHub project</a>
      </article>
    </div>
  </section>
</BaseLayout>
