---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="AI Notes" description="Public AI Field Notes by Bocheng Yin.">
  <section class="hero">
    <div>
      <p class="eyebrow">AI Field Notes</p>
      <h1>Practical notes for building with AI agents.</h1>
      <p>
        A public notebook for reusable agent components, field-tested workflows, and small experiments.
        The first published component is a planning skill for turning vague ideas into implementation-ready specs.
      </p>
    </div>
    <div class="meta-box">
      <strong>Current focus</strong>
      <span>Agentic coding workflows, reusable skills, and the boundary between planning, implementation, and verification.</span>
    </div>
  </section>

  <section class="section">
    <div class="grid">
      <article class="card">
        <div class="badge-row">
          <span class="badge green">Skill</span>
          <span class="badge">Active</span>
        </div>
        <h2>Grill Me</h2>
        <p>A pre-implementation interview skill that turns vague plans into implementation-ready specs.</p>
        <a href={`${base}components/skills/grill-me/`}>Read component</a>
      </article>

      <article class="card">
        <div class="badge-row">
          <span class="badge blue">Components</span>
        </div>
        <h2>Components</h2>
        <p>Reusable skills, commands, agents, hooks, templates, decision cards, and kits.</p>
        <a href={`${base}components/`}>Browse components</a>
      </article>

      <article class="card">
        <div class="badge-row">
          <span class="badge">Coming soon</span>
        </div>
        <h2>Experiments</h2>
        <p>Short writeups from tests, prototypes, and applied AI system experiments.</p>
        <a href={`${base}experiments/`}>View experiments</a>
      </article>
    </div>
  </section>
</BaseLayout>
