---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="AI Notes" description="Public AI Field Notes by Bocheng Yin.">
  <section class="hero">
    <div>
      <p class="eyebrow">AI Field Notes</p>
      <h1>Learning notes on agentic coding and AI engineering.</h1>
      <p>
        A public learning journal for practical AI building: how I use coding agents, how I study AI engineering
        patterns, and what I learn from running my own experiments.
      </p>
    </div>
    <div class="meta-box">
      <strong>Structure</strong>
      <span>Notes are organized by topic first. Reusable components, such as skills or MCP patterns, live inside those topic areas.</span>
    </div>
  </section>

  <section class="section">
    <div class="grid">
      <article class="card">
        <div class="badge-row">
          <span class="badge green">Active</span>
          <span class="badge">Skills / MCP / Hooks</span>
        </div>
        <h2>Agentic Coding</h2>
        <p>Notes on the agent workflows I actually use: favorite skills, MCP, hooks, subagents, and context management.</p>
        <a href={`${base}agentic-coding/`}>Open Agentic Coding</a>
      </article>

      <article class="card">
        <div class="badge-row">
          <span class="badge blue">Planned</span>
          <span class="badge">RAG / Loops</span>
        </div>
        <h2>AI Engineering</h2>
        <p>Study notes on RAG, loop engineering, evaluation, and enterprise AI implementation patterns.</p>
        <a href={`${base}ai-engineering/`}>Open AI Engineering</a>
      </article>

      <article class="card">
        <div class="badge-row">
          <span class="badge">Lab</span>
          <span class="badge">Active</span>
        </div>
        <h2>Experiments</h2>
        <p>Experiments from my own GitHub projects, starting with AI Wiki Toolkit as a memory research project.</p>
        <a href={`${base}experiments/`}>Open Experiments</a>
      </article>
    </div>
  </section>
</BaseLayout>
